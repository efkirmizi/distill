# python -u store_hints_imagenet.py --t_path './save/models/ResNet34_imagenet/ResNet34_333f7ec4.pth' --data_folder '/data/fake_imagenet/' "$@"

# # 2.step - clustering these representations:
# # we use 4 hint positions for imagenet experiments:
