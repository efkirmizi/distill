# export NUM_CLUSTERS=4
# export NUM_LAYERS=16

# python -u k_means.py --hints_dir '/results/ResNet34_333f7ec4' --num_clusters $NUM_CLUSTERS --num_layers $NUM_LAYERS --metric_name $METRIC_NAME "$@"

